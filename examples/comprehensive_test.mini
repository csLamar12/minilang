-- Comprehensive test of all features
let x = 10
let y = 20
let z = 30

-- Arithmetic with precedence
let result = x + y * z  -- Should be 10 + (20*30) = 610
display "x + y * z =" result

-- Complex condition with logical operators
if x < y and y < z or x == 10
    display "Complex condition is true"
end

-- While loop with break
let counter = 1  -- Changed from 'count' to 'counter' to avoid confusion
while counter <= 10
    if counter > 5
        break
    end
    display "Count:" counter
    counter = counter + 1
end

-- For loop with step
for i = 0 to 10 step 2
    display "Even:" i
end

-- Try-catch with division
try
    let a = 10
    let b = 0
    let c = a / b
    display "This won't print"
catch
    display "Caught division by zero"
end

display "Program completed!"




