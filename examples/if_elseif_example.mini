-- Example: If statements with elseif pattern using logical operators
let score = 85

if score >= 90
    display "Grade: A"
end

if score >= 80 and score < 90
    display "Grade: B"
end

if score >= 70 and score < 80
    display "Grade: C"
end

if score < 70
    display "Grade: F"
end

display "Done"
