# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS FOR STREAMLIT CLOUD DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. DO NOT commit secrets.toml to git (it is already in .gitignore).
#
# 2. When deploying to Streamlit Cloud:
#    a. Go to your app dashboard on https://share.streamlit.io
#    b. Click the ⚙ gear icon → "Secrets"
#    c. Paste the line below (with your real key) into the Secrets editor:
#
#        GOOGLE_API_KEY = "AIzaSy..."
#
#    d. Click "Save" — Streamlit Cloud will restart your app automatically.
#
# 3. For local development, you can either:
#    a. Create .streamlit/secrets.toml (same location as this file) and
#       add the line above with your real key, OR
#    b. Set the environment variable before running:
#         export GOOGLE_API_KEY="AIzaSy..."
#         streamlit run cloud_app.py
#
# Get a FREE Google API key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_API_KEY = "AIzaSy_REPLACE_WITH_YOUR_REAL_KEY"
